# Linglong Scout — 服务器端配置
# 用于 Docker 部署，敏感值通过 ${ENV_VAR} 从 .env 注入
# network_mode: host，所有服务用 127.0.0.1 访问

debug: false
log_level: "INFO"

llm:
  llm_api_key: ${ZHIPU_API_KEY}
  llm_base_url: "https://open.bigmodel.cn/api/anthropic"
  llm_model: "glm-5.1"

ingest:
  searxng_url: "http://127.0.0.1:8088"
  searxng_api_key: ${SEARXNG_API_KEY}
  search_timeout: 30

  rsshub_access_key: ${RSSHUB_ACCESS_KEY}

  llm_max_tokens: 8000
  llm_retries: 2
  llm_timeout: 120

  github_trending_limits:
    daily: 5
    weekly: 3
    monthly: 3
  github_search_fallback:
    since_days: 30
    min_stars: 500

  company_snapshot_path: ~/linglong/company_snapshot.json
  dedup_windows:
    关键人物: 14
    公司动态: 7
    政策动态: 14
    应用落地: 7

  brief_schedule_time: "07:30"

  rss_sources:
    - name: AIHOT
      url: https://aihot.virxact.com/feed
    - name: 36氪
      url: https://36kr.com/feed
    - name: 36氪快讯
      url: http://127.0.0.1:1200/36kr/newsflashes
    - name: 量子位
      url: https://www.qbitai.com/feed
    - name: The Rundown AI
      url: https://rss.beehiiv.com/feeds/2R3C6Bt5wj.xml
    - name: 华尔街见闻快讯
      url: http://127.0.0.1:1200/wallstreetcn/live
    - name: 财新网
      url: http://127.0.0.1:1200/caixin/latest
    - name: TechCrunch AI
      url: https://techcrunch.com/category/artificial-intelligence/feed/
    - name: The Verge AI
      url: https://www.theverge.com/rss/ai-artificial-intelligence/index.xml
    - name: 工信部文件公示
      url: http://127.0.0.1:1200/gov/miit/wjgs
    - name: 发改委新闻动态
      url: http://127.0.0.1:1200/gov/ndrc/xwdt

  packages:
    - name: ai-morning-brief
      topic: AI 早报
      output:
        format: morning-brief
        persist: true
      search_queries:
        - keywords:
            - "Karpathy AI latest opinion 2026"
            - "Sam Altman OpenAI latest 2026"
            - "Jensen Huang AI latest 2026"
          max_results: 3
          max_age_days: 3

mcp:
  transport: "streamable-http"
  host: "127.0.0.1"
  port: 9900
  auth_token: ${LL_MCP_AUTH_TOKEN}
  redis_url: ${REDIS_URL}
