# Linglong Scout 环境变量
# 复制为 .env 并填入实际值
# docker compose 会自动读取此文件

# MCP 认证 Token（格式：linglong-mcp-<random>）
LL_MCP_AUTH_TOKEN=your-secret-token

# LLM
ZHIPU_API_KEY=your-zhipu-key

# SearXNG
SEARXNG_API_KEY=your-searxng-key

# RSSHub
RSSHUB_ACCESS_KEY=your-rsshub-key

# Redis（含密码）
REDIS_URL=redis://:your-redis-password@127.0.0.1:6379/0
