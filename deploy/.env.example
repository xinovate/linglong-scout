# Linglong Scout 环境变量
# 复制为 .env 并填入实际值
# docker compose 会自动读取此文件

# MCP 服务配置
LL_SCOUT_MCP_TRANSPORT=streamable-http
LL_SCOUT_MCP_HOST=0.0.0.0
LL_SCOUT_MCP_PORT=9900
LL_SCOUT_MCP_AUTH_TOKEN=your-secret-token

# LLM
LL_SCOUT_LLM_API_KEY=your-zhipu-key

# SearXNG / RSSHub
LL_INGEST_SEARXNG_API_KEY=your-searxng-key
LL_INGEST_RSSHUB_ACCESS_KEY=your-rsshub-key
