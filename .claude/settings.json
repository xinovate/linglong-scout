{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["-c", "python3 ${CLAUDE_PROJECT_DIR}/scripts/session-context.py"],
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash",
            "args": ["-c", "python3 ${CLAUDE_PROJECT_DIR}/scripts/privacy-check.py"],
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash",
            "args": ["-c", "python3 ${CLAUDE_PROJECT_DIR}/scripts/doc-check.py --claude-hook"],
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "bash",
            "args": ["-c", "python3 ${CLAUDE_PROJECT_DIR}/scripts/journal-check.py --claude-hook"],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
