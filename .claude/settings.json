{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash",
            "args": ["-c", "python3 ${CLAUDE_PROJECT_DIR}/scripts/doc-check.py --claude-hook"],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
